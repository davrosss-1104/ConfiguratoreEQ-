{
  "id": "CONTATTORI_OLEO",
  "name": "Selezione contattori centralina oleodinamica",
  "description": "Lookup per potenza/avviamento/frequenza → contattore KM, KS, soft starter, fili, morsetti. Sostituisce 63 regole singole.",
  "version": "2.0",
  "enabled": true,
  "priority": 50,
  "conditions": [
    {
      "field": "argano.trazione",
      "operator": "equals",
      "value": "oleodinamica"
    }
  ],
  "actions": [
    {
      "action": "set_field",
      "field": "_calc.partizione_contattori",
      "value": "{{argano.tipo_avviamento_motore}}_{{tensioni.frequenza_rete}}Hz"
    },
    {
      "action": "lookup_table",
      "tabella": "contattori_oleo",
      "input_field": "argano.potenza_motore_kw",
      "partition_field": "_calc.partizione_contattori",
      "output_prefix": "_calc.cont."
    },
    {
      "action": "add_material",
      "skip_if": "_calc.cont.cont_km is_empty",
      "material": {
        "codice": "{{_calc.cont.cont_km}}",
        "descrizione": "Contattore {{_calc.cont.cont_km}} marcia (KM)",
        "quantita": 1,
        "prezzo_unitario": 0,
        "categoria": "Contattori",
        "note": "Avv. {{argano.tipo_avviamento_motore}} - {{argano.potenza_motore_kw}}kW"
      }
    },
    {
      "action": "add_material",
      "skip_if": "_calc.cont.cont_ks is_empty",
      "material": {
        "codice": "{{_calc.cont.cont_ks}}",
        "descrizione": "Contattore {{_calc.cont.cont_ks}} stella (KS)",
        "quantita": 1,
        "prezzo_unitario": 0,
        "categoria": "Contattori",
        "note": "Stella-triangolo - {{argano.potenza_motore_kw}}kW"
      }
    },
    {
      "action": "add_material",
      "skip_if": "_calc.cont.soft_starter is_empty",
      "material": {
        "codice": "{{_calc.cont.soft_starter}}",
        "descrizione": "Soft Starter {{_calc.cont.soft_starter}}",
        "quantita": 1,
        "prezzo_unitario": 0,
        "categoria": "Contattori",
        "note": "Motore {{argano.potenza_motore_kw}}kW"
      }
    },
    {
      "action": "add_material",
      "skip_if": "_calc.cont.sezione_morsetti is_empty",
      "material": {
        "codice": "MORS-{{_calc.cont.sezione_morsetti}}MM2-RST",
        "descrizione": "Morsetti {{_calc.cont.sezione_morsetti}}mm² linea R-S-T",
        "quantita": 3,
        "prezzo_unitario": 0,
        "categoria": "Morsetteria"
      }
    },
    {
      "action": "add_material",
      "skip_if": "_calc.cont.sezione_morsetti is_empty",
      "material": {
        "codice": "MORS-{{_calc.cont.sezione_morsetti}}MM2-UVW",
        "descrizione": "Morsetti {{_calc.cont.sezione_morsetti}}mm² motore U-V-W",
        "quantita": 3,
        "prezzo_unitario": 0,
        "categoria": "Morsetteria"
      }
    },
    {
      "action": "add_material",
      "skip_if": "_calc.cont.sezione_filo is_empty",
      "material": {
        "codice": "FILO-{{_calc.cont.sezione_filo}}MM2-RST",
        "descrizione": "Filo {{_calc.cont.sezione_filo}}mm² linea R-S-T",
        "quantita": 1,
        "prezzo_unitario": 0,
        "categoria": "Cablaggio"
      }
    },
    {
      "action": "add_material",
      "skip_if": "_calc.cont.sezione_filo is_empty",
      "material": {
        "codice": "FILO-{{_calc.cont.sezione_filo}}MM2-UVW",
        "descrizione": "Filo {{_calc.cont.sezione_filo}}mm² motore U-V-W",
        "quantita": 1,
        "prezzo_unitario": 0,
        "categoria": "Cablaggio"
      }
    }
  ]
}
