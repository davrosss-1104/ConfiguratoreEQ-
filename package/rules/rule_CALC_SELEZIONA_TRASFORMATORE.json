{
  "id": "CALC_SELEZIONA_TRASFORMATORE",
  "name": "Selezione trasformatore da catalogo",
  "description": "Phase 1: cerca nel catalogo il trasformatore più piccolo che copre tutte le uscite richieste",
  "version": "1.0",
  "enabled": true,
  "priority": 20,
  "phase": 1,
  "conditions": [
    {
      "field": "_calc.va_totali",
      "operator": "greater_than",
      "value": 0,
      "description": "Solo se ci sono VA da coprire"
    }
  ],
  "actions": [
    {
      "action": "catalog_match",
      "tabella": "catalogo_trasformatori",
      "criteri_dinamici": {
        "pattern": "usc_{key}v_va",
        "sorgente_prefix": "_calc.va_richiesti_",
        "sorgente_suffix": "v",
        "operatore": ">=",
        "solo_se_maggiore_di": 0
      },
      "criteri_fissi": [
        {
          "colonna": "potenza_va",
          "operatore": ">=",
          "valore": "{{_calc.va_totali}}"
        }
      ],
      "ordinamento": {
        "colonna": "potenza_va",
        "direzione": "ASC"
      },
      "output": {
        "_calc.codice_trasformatore": "codice",
        "_calc.tipo_trasformatore": "tipo",
        "_calc.potenza_trasformatore": "potenza_va"
      }
    }
  ]
}
